# ──────────────────────────────────────────────────────────
# FinTrack Landing Page — Environment Variables
# ──────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
#   cp .env.example .env
#
# NEVER commit the real .env file to Git.
# Add secrets as Environment Variables in Vercel instead:
#   https://vercel.com/docs/environment-variables
# ──────────────────────────────────────────────────────────

# Backend URL (only needed in development)
REACT_APP_BACKEND_URL=http://localhost:8001

# Dev-server websocket port (CRA hot-reload)
WDS_SOCKET_PORT=3002

# Health-check plugin (set to "true" to enable)
ENABLE_HEALTH_CHECK=false

# ─── Supabase ────────────────────────────────────────────
# Get these from https://app.supabase.com → Settings → API
REACT_APP_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_anon_key_here
REACT_APP_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here

# Expo mobile-web URL (only needed when running alongside the RN app)
REACT_APP_EXPO_WEB_URL=http://localhost:8081

# ─── Google Analytics 4 ──────────────────────────────────
# Optional — leave blank to disable tracking in development
REACT_APP_GA_ID=G-XXXXXXXXXX

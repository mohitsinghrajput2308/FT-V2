{
  "mcp": {
    "servers": {
      "code-review-graph": {
        "command": "node",
        "args": [
          "mcp-server.js"
        ],
        "cwd": "${workspaceFolder}/code-review-graph",
        "env": {
          "NODE_PATH": "${workspaceFolder}/code-review-graph/node_modules"
        }
      }
    }
  }
}
